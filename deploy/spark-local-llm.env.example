# Copy only to the DGX Spark node as .env.spark-local-llm; do not commit secrets.
# Download one model directly on Spark; never upload model weights through SSH/SCP.
MODEL_HANDLE=nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4
TRTLLM_IMAGE=nvcr.io/nvidia/tensorrt-llm/release:1.3.0rc13
TRTLLM_PORT=8355
MAX_BATCH_SIZE=8
HF_TOKEN=replace-with-Hugging-Face-token
